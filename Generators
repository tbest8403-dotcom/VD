--// Violence District - Generator Auto Success Replacement
--// Upload this full file to your GitHub VD/Generators file.
--//
--// No radius, movement, or teleporting.
--// Only reacts after the player manually starts repairing.
--// Removes every Skillcheck-gen LocalScript added under the character.
--// Rebuilds generator highlights automatically between rounds.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local GeneratorRemotes =
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("Generator")

local SkillCheckEvent =
	GeneratorRemotes:WaitForChild("SkillCheckEvent")

local SkillCheckResultEvent =
	GeneratorRemotes:WaitForChild("SkillCheckResultEvent")

local KingScourgeRemotes =
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("KillerPerks")
		:WaitForChild("kingscourge")

local KingScourgeStart =
	KingScourgeRemotes:WaitForChild("KingScourgeStart")

local KingScourgeHit =
	KingScourgeRemotes:WaitForChild("KingScourgeHit")

local KingScourgeEnd =
	KingScourgeRemotes:WaitForChild("KingScourgeEnd")

local Environment = getgenv and getgenv() or _G

local GeneratorLogic = {}
GeneratorLogic.__index = GeneratorLogic

local function Disconnect(Connection)
	if Connection and Connection.Connected then
		Connection:Disconnect()
	end
end

local function DisconnectList(Connections)
	for _, Connection in ipairs(Connections) do
		Disconnect(Connection)
	end

	table.clear(Connections)
end

local function SetConnectionEnabled(Connection, Enabled)
	if not Connection then
		return false
	end

	local MethodName = Enabled and "Enable" or "Disable"

	return pcall(function()
		local Method = Connection[MethodName]

		if type(Method) ~= "function" then
			error(MethodName .. " is unavailable")
		end

		Method(Connection)
	end)
end

local function GetGeneratorAdornee(Point)
	if not Point then
		return nil
	end

	if Point.Parent and Point.Parent:IsA("Model") then
		return Point.Parent
	end

	return Point
end

function GeneratorLogic.new(Options)
	Options = Options or {}

	local self = setmetatable({}, GeneratorLogic)

	self.Settings = {
		AutoSkillCheck =
			Options.AutoSkillCheck ~= false,

		HighlightsEnabled =
			Options.HighlightsEnabled ~= false,

		NormalDelay =
			tonumber(Options.NormalDelay)
			or 0.52,

		ScourgeDelay =
			tonumber(Options.ScourgeDelay)
			or 0.2,

		GuiHoldTime =
			tonumber(Options.GuiHoldTime)
			or 0.1,

		ReplacementRetryDelay =
			tonumber(Options.ReplacementRetryDelay)
			or 0.1,

		HighlightRefreshDelay =
			tonumber(Options.HighlightRefreshDelay)
			or 0.25,

		SuccessOffset =
			tonumber(Options.SuccessOffset)
			or 109,

		TargetScriptName =
			Options.TargetScriptName
			or "Skillcheck-gen",

		HighlightColor =
			Options.HighlightColor
			or Color3.fromRGB(255, 196, 64),

		HighlightFillTransparency =
			tonumber(Options.HighlightFillTransparency)
			or 1,

		HighlightOutlineTransparency =
			tonumber(Options.HighlightOutlineTransparency)
			or 0,

		HighlightDepthMode =
			Options.HighlightDepthMode
			or Enum.HighlightDepthMode.AlwaysOnTop,

		HighlightContainerName =
			Options.HighlightContainerName
			or "VD_GeneratorHighlights",

		SoundContainerName =
			Options.SoundContainerName
			or "VD_GeneratorSounds",
	}

	self.State = {
		Running = false,
		Status = "Created",
		SuccessfulChecks = 0,
		LastCheck = "None",
		RemovedScripts = 0,
		HighlightedGenerators = 0,
	}

	self._Running = false
	self._Destroyed = false
	self._NormalToken = 0
	self._ScourgeToken = 0
	self._Connections = {}
	self._CharacterConnections = {}
	self._DisabledConnections = {}
	self._Highlights = {}
	self._HighlightContainer = nil
	self._SoundContainer = nil
	self._HighlightRefreshQueued = false

	self._StatusChanged = Instance.new("BindableEvent")
	self._Success = Instance.new("BindableEvent")

	self:_CreateHighlightContainer()
	self:_CreateSoundContainer()

	return self
end

--// Public events

function GeneratorLogic:OnStatusChanged(Callback)
	return self._StatusChanged.Event:Connect(Callback)
end

function GeneratorLogic:OnSuccess(Callback)
	return self._Success.Event:Connect(Callback)
end

function GeneratorLogic:_SetStatus(Status)
	Status = tostring(Status)

	if self.State.Status == Status then
		return
	end

	self.State.Status = Status
	self._StatusChanged:Fire(Status, self:GetState())
end

function GeneratorLogic:GetState()
	return {
		Running = self.State.Running,
		Status = self.State.Status,
		SuccessfulChecks = self.State.SuccessfulChecks,
		LastCheck = self.State.LastCheck,
		RemovedScripts = self.State.RemovedScripts,
		HighlightedGenerators = self.State.HighlightedGenerators,
		AutoSkillCheck = self.Settings.AutoSkillCheck,
		HighlightsEnabled = self.Settings.HighlightsEnabled,
	}
end

--// Character and repair state

function GeneratorLogic:_GetCharacter()
	return LocalPlayer.Character
end

function GeneratorLogic:_GetCheckInterractable()
	local Character = self:_GetCharacter()

	if not Character then
		return nil
	end

	return Character:FindFirstChild(
		"CheckInterractable",
		true
	)
end

function GeneratorLogic:_IsRepairing()
	local CheckInterractable =
		self:_GetCheckInterractable()

	return CheckInterractable ~= nil
		and CheckInterractable:GetAttribute(
			"isRepairing"
		) == true
end

--// Original LocalScript removal

function GeneratorLogic:_IsTargetSkillCheckScript(Instance)
	return Instance ~= nil
		and Instance:IsA("LocalScript")
		and string.lower(Instance.Name)
			== string.lower(
				self.Settings.TargetScriptName
			)
end

function GeneratorLogic:_CreateSoundContainer()
	local Existing =
		PlayerGui:FindFirstChild(
			self.Settings.SoundContainerName
		)

	if Existing then
		Existing:Destroy()
	end

	local Folder = Instance.new("Folder")
	Folder.Name = self.Settings.SoundContainerName
	Folder.Parent = PlayerGui

	self._SoundContainer = Folder
end

function GeneratorLogic:_CacheSounds(Source)
	if not Source then
		return
	end

	if not self._SoundContainer
		or not self._SoundContainer.Parent
	then
		self:_CreateSoundContainer()
	end

	for _, Name in ipairs({
		"Sound",
		"Confirm",
		"Great",
	}) do
		if not self._SoundContainer:FindFirstChild(Name) then
			local OriginalSound = Source:FindFirstChild(Name)

			if OriginalSound
				and OriginalSound:IsA("Sound")
			then
				local Clone = OriginalSound:Clone()
				Clone.Name = Name
				Clone.Parent = self._SoundContainer
			end
		end
	end
end

function GeneratorLogic:_RemoveSkillCheckScript(Instance)
	if not self:_IsTargetSkillCheckScript(Instance) then
		return false
	end

	self:_CacheSounds(Instance)

	pcall(function()
		Instance.Disabled = true
	end)

	local Destroyed = pcall(function()
		Instance:Destroy()
	end)

	if Destroyed then
		self.State.RemovedScripts += 1
		return true
	end

	return false
end

function GeneratorLogic:_ScanCharacterForSkillCheckScripts(Character)
	if not Character then
		return 0
	end

	local RemovedCount = 0

	for _, Descendant in ipairs(Character:GetDescendants()) do
		if self:_RemoveSkillCheckScript(Descendant) then
			RemovedCount += 1
		end
	end

	return RemovedCount
end

function GeneratorLogic:_FindWorkspaceSkillCheckScript()
	local Apatiest = workspace:FindFirstChild("Apatiest")

	if not Apatiest then
		return nil
	end

	return Apatiest:FindFirstChild(
		self.Settings.TargetScriptName,
		true
	)
end

function GeneratorLogic:_RemoveWorkspaceSkillCheckScript()
	local Original =
		self:_FindWorkspaceSkillCheckScript()

	if not Original then
		return false
	end

	if Original:IsA("LocalScript") then
		return self:_RemoveSkillCheckScript(Original)
	end

	self:_CacheSounds(Original)

	pcall(function()
		Original.Disabled = true
	end)

	local Destroyed = pcall(function()
		Original:Destroy()
	end)

	if Destroyed then
		self.State.RemovedScripts += 1
	end

	return Destroyed
end

function GeneratorLogic:_BindCharacterWatcher(Character)
	DisconnectList(self._CharacterConnections)

	if not Character then
		return
	end

	self:_ScanCharacterForSkillCheckScripts(Character)

	table.insert(
		self._CharacterConnections,
		Character.DescendantAdded:Connect(function(Descendant)
			if self:_RemoveSkillCheckScript(Descendant) then
				self:_SetStatus(
					"Removed character Skillcheck-gen"
				)
			end
		end)
	)

	table.insert(
		self._CharacterConnections,
		Character.AncestryChanged:Connect(function(_, Parent)
			if not Parent then
				DisconnectList(
					self._CharacterConnections
				)
			end
		end)
	)
end

function GeneratorLogic:_StartScriptRemovalLoop()
	task.spawn(function()
		while self._Running and not self._Destroyed do
			local Character = self:_GetCharacter()

			if Character then
				self:_ScanCharacterForSkillCheckScripts(
					Character
				)
			end

			self:_RemoveWorkspaceSkillCheckScript()

			task.wait(
				self.Settings.ReplacementRetryDelay
			)
		end
	end)
end

--// Disable already-running original handlers

function GeneratorLogic:_DisableSignalConnections(Signal)
	local GetConnectionsFunction =
		Environment.getconnections

	if type(GetConnectionsFunction) ~= "function" then
		return 0
	end

	local Success, Connections = pcall(
		GetConnectionsFunction,
		Signal
	)

	if not Success or type(Connections) ~= "table" then
		return 0
	end

	local DisabledCount = 0

	for _, Connection in ipairs(Connections) do
		if SetConnectionEnabled(Connection, false) then
			table.insert(
				self._DisabledConnections,
				Connection
			)

			DisabledCount += 1
		end
	end

	return DisabledCount
end

function GeneratorLogic:_DisableOriginalConnections()
	local DisabledCount = 0

	DisabledCount +=
		self:_DisableSignalConnections(
			SkillCheckEvent.OnClientEvent
		)

	DisabledCount +=
		self:_DisableSignalConnections(
			KingScourgeStart.OnClientEvent
		)

	DisabledCount +=
		self:_DisableSignalConnections(
			KingScourgeEnd.OnClientEvent
		)

	local SurvivorGui =
		PlayerGui:FindFirstChild("Survivor-mob")

	local Controls =
		SurvivorGui
		and SurvivorGui:FindFirstChild("Controls")

	local ActionButton =
		Controls
		and Controls:FindFirstChild("action")

	if ActionButton then
		DisabledCount +=
			self:_DisableSignalConnections(
				ActionButton.MouseButton1Down
			)
	end

	return DisabledCount
end

function GeneratorLogic:_RestoreOriginalConnections()
	for _, Connection in ipairs(
		self._DisabledConnections
	) do
		SetConnectionEnabled(Connection, true)
	end

	table.clear(self._DisabledConnections)
end

--// Skill-check GUI

function GeneratorLogic:_GetGuiReferences()
	local SkillCheckGui =
		PlayerGui:FindFirstChild("SkillCheckPromptGui")

	local CheckFrame =
		SkillCheckGui
		and SkillCheckGui:FindFirstChild("Check")

	local Line =
		CheckFrame
		and CheckFrame:FindFirstChild("Line")

	local Goal =
		CheckFrame
		and CheckFrame:FindFirstChild("Goal")

	local SurvivorGui =
		PlayerGui:FindFirstChild("Survivor-mob")

	local Controls =
		SurvivorGui
		and SurvivorGui:FindFirstChild("Controls")

	local ActionButton =
		Controls
		and Controls:FindFirstChild("action")

	local ActionCheck =
		ActionButton
		and ActionButton:FindFirstChild("check")

	return {
		SkillCheckGui = SkillCheckGui,
		CheckFrame = CheckFrame,
		Line = Line,
		Goal = Goal,
		ActionButton = ActionButton,
		ActionCheck = ActionCheck,
	}
end

function GeneratorLogic:_ShowSuccessGui()
	local Gui = self:_GetGuiReferences()

	if not Gui.CheckFrame
		or not Gui.Line
		or not Gui.Goal
	then
		return nil,
			"Skill-check GUI objects were not found"
	end

	Gui.CheckFrame.Visible = true

	if Gui.ActionCheck then
		Gui.ActionCheck.Visible = true
	end

	Gui.Goal.Rotation = math.random(0, 200)
	Gui.Line.Rotation =
		Gui.Goal.Rotation
		+ self.Settings.SuccessOffset

	return Gui
end

function GeneratorLogic:_HideSuccessGui(Gui)
	if not Gui then
		Gui = self:_GetGuiReferences()
	end

	if Gui.CheckFrame then
		Gui.CheckFrame.Visible = false
	end

	if Gui.ActionCheck then
		Gui.ActionCheck.Visible = false
	end

	if Gui.Line then
		Gui.Line.Rotation = 0
	end

	if Gui.Goal then
		Gui.Goal.Rotation = 0
	end
end

function GeneratorLogic:_PlayGuiSound(Name)
	if not self._SoundContainer
		or not self._SoundContainer.Parent
	then
		return
	end

	local Sound = self._SoundContainer:FindFirstChild(Name)

	if Sound and Sound:IsA("Sound") then
		pcall(function()
			Sound:Play()
		end)
	end
end

function GeneratorLogic:_RecordSuccess(CheckType)
	self.State.SuccessfulChecks += 1
	self.State.LastCheck = tostring(CheckType)

	self._Success:Fire(
		CheckType,
		self.State.SuccessfulChecks,
		self:GetState()
	)

	self:_SetStatus(
		tostring(CheckType)
			.. " success | Total: "
			.. tostring(
				self.State.SuccessfulChecks
			)
	)
end

--// Normal generator checks

function GeneratorLogic:_HandleNormalSkillCheck(
	RepairPoint,
	GeneratorPoint
)
	if not self.Settings.AutoSkillCheck
		or not self._Running
		or self._Destroyed
	then
		return
	end

	if not self:_IsRepairing() then
		return
	end

	self._NormalToken += 1
	local Token = self._NormalToken

	task.spawn(function()
		task.wait(self.Settings.NormalDelay)

		if self._Destroyed
			or not self._Running
			or not self.Settings.AutoSkillCheck
			or self._NormalToken ~= Token
			or not self:_IsRepairing()
		then
			return
		end

		local Gui, GuiError =
			self:_ShowSuccessGui()

		if not Gui then
			self:_SetStatus(GuiError)
			return
		end

		task.wait()

		if self._NormalToken ~= Token
			or not self:_IsRepairing()
		then
			self:_HideSuccessGui(Gui)
			return
		end

		local Success, ErrorMessage = pcall(function()
			SkillCheckResultEvent:FireServer(
				"success",
				1,
				RepairPoint,
				GeneratorPoint
			)
		end)

		if Success then
			self:_PlayGuiSound("Great")
			self:_RecordSuccess("Normal")
		else
			self:_SetStatus(
				"Normal success failed: "
					.. tostring(ErrorMessage)
			)
		end

		task.wait(self.Settings.GuiHoldTime)
		self:_HideSuccessGui(Gui)
	end)
end

--// King Scourge checks

function GeneratorLogic:_HandleKingScourge(
	RepairPoint,
	ScourgeId,
	CheckCount
)
	if not self.Settings.AutoSkillCheck
		or not self._Running
		or self._Destroyed
		or not self:_IsRepairing()
	then
		return
	end

	CheckCount = math.max(
		1,
		math.floor(tonumber(CheckCount) or 1)
	)

	self._ScourgeToken += 1
	local Token = self._ScourgeToken

	task.spawn(function()
		for Index = 1, CheckCount do
			if self._Destroyed
				or not self._Running
				or not self.Settings.AutoSkillCheck
				or self._ScourgeToken ~= Token
				or not self:_IsRepairing()
			then
				return
			end

			local Gui, GuiError =
				self:_ShowSuccessGui()

			if not Gui then
				self:_SetStatus(GuiError)
				return
			end

			task.wait(self.Settings.ScourgeDelay)

			if self._ScourgeToken ~= Token
				or not self:_IsRepairing()
			then
				self:_HideSuccessGui(Gui)
				return
			end

			local Success, ErrorMessage = pcall(function()
				KingScourgeHit:FireServer(
					ScourgeId,
					"success"
				)
			end)

			if not Success then
				self:_SetStatus(
					"King Scourge success failed: "
						.. tostring(ErrorMessage)
				)

				self:_HideSuccessGui(Gui)
				return
			end

			self:_PlayGuiSound("Great")
			self:_RecordSuccess(
				"King Scourge "
					.. tostring(Index)
					.. "/"
					.. tostring(CheckCount)
			)

			task.wait(self.Settings.GuiHoldTime)
			self:_HideSuccessGui(Gui)
			task.wait(0.05)
		end
	end)
end

--// Generator highlights

function GeneratorLogic:_CreateHighlightContainer()
	local Existing =
		PlayerGui:FindFirstChild(
			self.Settings.HighlightContainerName
		)

	if Existing then
		Existing:Destroy()
	end

	local Folder = Instance.new("Folder")
	Folder.Name =
		self.Settings.HighlightContainerName
	Folder.Parent = PlayerGui

	self._HighlightContainer = Folder
end

function GeneratorLogic:_ClearHighlights()
	for Adornee, Highlight in pairs(self._Highlights) do
		self._Highlights[Adornee] = nil

		if Highlight then
			Highlight:Destroy()
		end
	end

	self.State.HighlightedGenerators = 0
end

function GeneratorLogic:_IsGeneratorPointAvailable(Point)
	if not Point
		or not Point:IsA("BasePart")
		or not Point:IsDescendantOf(workspace)
	then
		return false
	end

	if not CollectionService:HasTag(
		Point,
		"GeneratorPoint"
	) then
		return false
	end

	local Parent = Point.Parent

	if CollectionService:HasTag(Point, "Blocked")
		or (
			Parent
			and CollectionService:HasTag(
				Parent,
				"Blocked"
			)
		)
	then
		return false
	end

	return true
end

function GeneratorLogic:_CreateHighlight(Adornee)
	if not self._HighlightContainer
		or not self._HighlightContainer.Parent
	then
		self:_CreateHighlightContainer()
	end

	local Highlight = Instance.new("Highlight")
	Highlight.Name = "VD_GeneratorESP"
	Highlight.Adornee = Adornee
	Highlight.FillColor = self.Settings.HighlightColor
	Highlight.OutlineColor = self.Settings.HighlightColor
	Highlight.FillTransparency =
		self.Settings.HighlightFillTransparency
	Highlight.OutlineTransparency =
		self.Settings.HighlightOutlineTransparency
	Highlight.DepthMode =
		self.Settings.HighlightDepthMode
	Highlight.Enabled = true
	Highlight.Parent = self._HighlightContainer

	self._Highlights[Adornee] = Highlight

	return Highlight
end

function GeneratorLogic:_RefreshHighlights()
	if self._Destroyed then
		return
	end

	if not self.Settings.HighlightsEnabled then
		self:_ClearHighlights()
		return
	end

	if not self._HighlightContainer
		or not self._HighlightContainer.Parent
	then
		self:_CreateHighlightContainer()
	end

	local ValidAdornees = {}

	for _, Point in ipairs(
		CollectionService:GetTagged("GeneratorPoint")
	) do
		if self:_IsGeneratorPointAvailable(Point) then
			local Adornee = GetGeneratorAdornee(Point)

			if Adornee
				and Adornee:IsDescendantOf(workspace)
			then
				ValidAdornees[Adornee] = true

				local Highlight =
					self._Highlights[Adornee]

				if not Highlight
					or not Highlight.Parent
					or Highlight.Adornee ~= Adornee
				then
					if Highlight then
						Highlight:Destroy()
					end

					Highlight =
						self:_CreateHighlight(Adornee)
				end

				Highlight.FillColor =
					self.Settings.HighlightColor
				Highlight.OutlineColor =
					self.Settings.HighlightColor
				Highlight.FillTransparency =
					self.Settings.HighlightFillTransparency
				Highlight.OutlineTransparency =
					self.Settings.HighlightOutlineTransparency
				Highlight.DepthMode =
					self.Settings.HighlightDepthMode
				Highlight.Enabled = true
			end
		end
	end

	local RemoveList = {}

	for Adornee, Highlight in pairs(self._Highlights) do
		if not ValidAdornees[Adornee]
			or not Adornee.Parent
			or not Highlight
			or not Highlight.Parent
		then
			table.insert(RemoveList, Adornee)
		end
	end

	for _, Adornee in ipairs(RemoveList) do
		local Highlight = self._Highlights[Adornee]
		self._Highlights[Adornee] = nil

		if Highlight then
			Highlight:Destroy()
		end
	end

	local HighlightCount = 0

	for _, Highlight in pairs(self._Highlights) do
		if Highlight
			and Highlight.Parent
			and Highlight.Enabled
		then
			HighlightCount += 1
		end
	end

	self.State.HighlightedGenerators = HighlightCount
end

function GeneratorLogic:_QueueHighlightRefresh()
	if self._HighlightRefreshQueued
		or self._Destroyed
	then
		return
	end

	self._HighlightRefreshQueued = true

	task.defer(function()
		self._HighlightRefreshQueued = false

		if self._Running and not self._Destroyed then
			pcall(function()
				self:_RefreshHighlights()
			end)
		end
	end)
end

function GeneratorLogic:_BindHighlightWatchers()
	table.insert(
		self._Connections,
		CollectionService:GetInstanceAddedSignal(
			"GeneratorPoint"
		):Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		CollectionService:GetInstanceRemovedSignal(
			"GeneratorPoint"
		):Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		CollectionService:GetInstanceAddedSignal(
			"Blocked"
		):Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		CollectionService:GetInstanceRemovedSignal(
			"Blocked"
		):Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		workspace.ChildAdded:Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		workspace.ChildRemoved:Connect(function()
			self:_QueueHighlightRefresh()
		end)
	)

	table.insert(
		self._Connections,
		PlayerGui.ChildRemoved:Connect(function(Child)
			if Child == self._HighlightContainer then
				self._HighlightContainer = nil
				self:_QueueHighlightRefresh()
			end
		end)
	)
end

function GeneratorLogic:_StartHighlightLoop()
	task.spawn(function()
		while self._Running and not self._Destroyed do
			pcall(function()
				self:_RefreshHighlights()
			end)

			task.wait(
				self.Settings.HighlightRefreshDelay
			)
		end
	end)
end

--// Bindings

function GeneratorLogic:_BindReplacementConnections()
	table.insert(
		self._Connections,
		SkillCheckEvent.OnClientEvent:Connect(
			function(RepairPoint, GeneratorPoint)
				self:_HandleNormalSkillCheck(
					RepairPoint,
					GeneratorPoint
				)
			end
		)
	)

	table.insert(
		self._Connections,
		KingScourgeStart.OnClientEvent:Connect(
			function(
				RepairPoint,
				ScourgeId,
				CheckCount
			)
				self:_HandleKingScourge(
					RepairPoint,
					ScourgeId,
					CheckCount
				)
			end
		)
	)

	table.insert(
		self._Connections,
		KingScourgeEnd.OnClientEvent:Connect(
			function()
				self._ScourgeToken += 1
				self:_HideSuccessGui()
			end
		)
	)

	table.insert(
		self._Connections,
		LocalPlayer.CharacterAdded:Connect(
			function(Character)
				self._NormalToken += 1
				self._ScourgeToken += 1
				self:_HideSuccessGui()
				self:_BindCharacterWatcher(Character)
				self:_QueueHighlightRefresh()
			end
		)
	)
end

--// Settings

function GeneratorLogic:SetAutoSkillCheck(Enabled)
	self.Settings.AutoSkillCheck = Enabled == true
	self._NormalToken += 1
	self._ScourgeToken += 1

	if not self.Settings.AutoSkillCheck then
		self:_HideSuccessGui()
	end

	self:_SetStatus(
		"Auto Skill Check: "
			.. (
				self.Settings.AutoSkillCheck
					and "ON"
					or "OFF"
			)
	)
end

function GeneratorLogic:SetHighlightsEnabled(Enabled)
	self.Settings.HighlightsEnabled = Enabled == true
	self:_RefreshHighlights()

	self:_SetStatus(
		"Generator Highlights: "
			.. (
				self.Settings.HighlightsEnabled
					and "ON"
					or "OFF"
			)
	)
end

--// Lifecycle

function GeneratorLogic:Start()
	if self._Destroyed then
		return false, "Generator logic was destroyed"
	end

	if self._Running then
		return true
	end

	self._Running = true
	self.State.Running = true

	local DisabledCount =
		self:_DisableOriginalConnections()

	self:_RemoveWorkspaceSkillCheckScript()
	self:_BindCharacterWatcher(self:_GetCharacter())
	self:_BindReplacementConnections()
	self:_BindHighlightWatchers()
	self:_StartScriptRemovalLoop()
	self:_StartHighlightLoop()
	self:_RefreshHighlights()

	self:_SetStatus(
		"Ready | Disabled "
			.. tostring(DisabledCount)
			.. " old connections"
	)

	return true
end

function GeneratorLogic:Stop()
	if not self._Running then
		return
	end

	self._Running = false
	self.State.Running = false
	self._NormalToken += 1
	self._ScourgeToken += 1

	self:_HideSuccessGui()
	DisconnectList(self._CharacterConnections)
	DisconnectList(self._Connections)
	self:_RestoreOriginalConnections()
	self:_SetStatus("Generator replacement stopped")
end

function GeneratorLogic:Destroy()
	if self._Destroyed then
		return
	end

	self:Stop()
	self._Destroyed = true
	self:_ClearHighlights()

	if self._HighlightContainer then
		self._HighlightContainer:Destroy()
		self._HighlightContainer = nil
	end

	if self._SoundContainer then
		self._SoundContainer:Destroy()
		self._SoundContainer = nil
	end

	self._StatusChanged:Destroy()
	self._Success:Destroy()
end

return GeneratorLogic

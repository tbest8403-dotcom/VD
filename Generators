--// Violence District - Generator Highlights + Auto Skill Check
--// Replace the contents of GitHub: VD/Generators with this full file.
--//
--// Features:
--//   - Generator highlights only.
--//   - Automatic normal generator skill-check success.
--//   - Automatic King Scourge chained skill-check success.
--//   - Uses the game's own action-button connection so the original GUI,
--//     sounds, cleanup, and server result behavior run normally.
--//   - No automatic repairing.
--//   - No repair GUI hiding.

local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local GeneratorRemotes =
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("Generator")

local SkillCheckEvent =
	GeneratorRemotes:WaitForChild("SkillCheckEvent")

local KillerPerksRemotes =
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("KillerPerks")

local KingScourgeRemotes =
	KillerPerksRemotes:WaitForChild("kingscourge")

local KingScourgeStart =
	KingScourgeRemotes:WaitForChild("KingScourgeStart")

local KingScourgeEnd =
	KingScourgeRemotes:WaitForChild("KingScourgeEnd")

local Environment = getgenv and getgenv() or _G

local GeneratorLogic = {}
GeneratorLogic.__index = GeneratorLogic

local function Disconnect(Connection)
	if Connection and Connection.Connected then
		Connection:Disconnect()
	end
end

local function CopyTable(Source)
	local Result = {}

	for Key, Value in pairs(Source) do
		Result[Key] = Value
	end

	return Result
end

local function GetGeneratorAdornee(Point)
	if not Point then
		return nil
	end

	local Parent = Point.Parent

	if Parent and Parent:IsA("Model") then
		return Parent
	end

	return Point
end

function GeneratorLogic.new(Options)
	Options = Options or {}

	local self = setmetatable({}, GeneratorLogic)

	self.Settings = {
		AutoSkillCheck =
			Options.AutoSkillCheck ~= false,

		HighlightsEnabled =
			Options.HighlightsEnabled ~= false,

		RefreshInterval =
			tonumber(Options.RefreshInterval)
			or 0.25,

		NormalCheckTimeout =
			tonumber(Options.NormalCheckTimeout)
			or 1.25,

		ScourgeCheckTimeout =
			tonumber(Options.ScourgeCheckTimeout)
			or 1,

		ScourgeCheckDelay =
			tonumber(Options.ScourgeCheckDelay)
			or 0.12,

		SuccessOffset =
			tonumber(Options.SuccessOffset)
			or 109,

		HighlightFillTransparency =
			tonumber(Options.HighlightFillTransparency)
			or 1,

		HighlightOutlineTransparency =
			tonumber(Options.HighlightOutlineTransparency)
			or 0,

		HighlightColor =
			Options.HighlightColor
			or Color3.fromRGB(255, 196, 64),

		HighlightDepthMode =
			Options.HighlightDepthMode
			or Enum.HighlightDepthMode.AlwaysOnTop,

		ContainerName =
			Options.ContainerName
			or "VD_GeneratorHighlights",
	}

	self.State = {
		Running = false,
		Status = "Created",
		AutoSkillCheck = self.Settings.AutoSkillCheck,
		HighlightsEnabled = self.Settings.HighlightsEnabled,
		HighlightedGenerators = 0,
		SuccessfulSkillChecks = 0,
		LastSkillCheck = "None",
	}

	self.HighlightContainer = nil
	self.Highlights = {}

	self.SkillCheckGui = nil
	self.CheckFrame = nil
	self.Line = nil
	self.Goal = nil
	self.ActionButton = nil
	self.ActionCheck = nil

	self._Running = false
	self._Destroyed = false
	self._EventsBound = false
	self._NormalToken = 0
	self._ScourgeToken = 0
	self._Connections = {}

	self._StatusEvent = Instance.new("BindableEvent")
	self._StateChangedEvent = Instance.new("BindableEvent")
	self._HighlightChangedEvent = Instance.new("BindableEvent")
	self._SkillCheckEvent = Instance.new("BindableEvent")

	self:_CreateHighlightContainer()
	self:_RefreshGuiReferences()

	return self
end

--// Events

function GeneratorLogic:OnStatusChanged(Callback)
	return self._StatusEvent.Event:Connect(Callback)
end

function GeneratorLogic:OnStateChanged(Callback)
	return self._StateChangedEvent.Event:Connect(Callback)
end

function GeneratorLogic:OnHighlightChanged(Callback)
	return self._HighlightChangedEvent.Event:Connect(Callback)
end

function GeneratorLogic:OnSkillCheckSuccess(Callback)
	return self._SkillCheckEvent.Event:Connect(Callback)
end

function GeneratorLogic:_SetStatus(Message)
	Message = tostring(Message)

	if self.State.Status == Message then
		return
	end

	self.State.Status = Message
	self._StatusEvent:Fire(Message, self:GetState())
	self:_EmitState()
end

function GeneratorLogic:_EmitState()
	self.State.AutoSkillCheck =
		self.Settings.AutoSkillCheck

	self.State.HighlightsEnabled =
		self.Settings.HighlightsEnabled

	self.State.HighlightedGenerators =
		self:GetHighlightCount()

	self._StateChangedEvent:Fire(self:GetState())
end

function GeneratorLogic:GetState()
	return {
		Running = self.State.Running,
		Status = self.State.Status,
		AutoSkillCheck = self.Settings.AutoSkillCheck,
		HighlightsEnabled = self.Settings.HighlightsEnabled,
		HighlightedGenerators = self:GetHighlightCount(),
		SuccessfulSkillChecks =
			self.State.SuccessfulSkillChecks,
		LastSkillCheck = self.State.LastSkillCheck,
	}
end

--// Generator validation

function GeneratorLogic:_HasCompletionFlag(Instance)
	if not Instance then
		return false
	end

	for _, Name in ipairs({
		"Completed",
		"Complete",
		"Repaired",
		"Finished",
		"Done",
	}) do
		if Instance:GetAttribute(Name) == true then
			return true
		end

		local Object = Instance:FindFirstChild(Name)

		if Object
			and Object:IsA("BoolValue")
			and Object.Value
		then
			return true
		end
	end

	for _, Name in ipairs({
		"RepairProgress",
		"GeneratorProgress",
		"Progress",
	}) do
		local Attribute = Instance:GetAttribute(Name)

		if typeof(Attribute) == "number"
			and (Attribute >= 100 or Attribute == 1)
		then
			return true
		end

		local Object = Instance:FindFirstChild(Name)

		if Object
			and (
				Object:IsA("NumberValue")
				or Object:IsA("IntValue")
			)
			and (Object.Value >= 100 or Object.Value == 1)
		then
			return true
		end
	end

	return false
end

function GeneratorLogic:_IsGeneratorAvailable(Point)
	if not Point
		or not Point:IsA("BasePart")
		or not Point:IsDescendantOf(workspace)
	then
		return false
	end

	if not CollectionService:HasTag(
		Point,
		"GeneratorPoint"
	) then
		return false
	end

	local Parent = Point.Parent

	if CollectionService:HasTag(Point, "Blocked")
		or (
			Parent
			and CollectionService:HasTag(
				Parent,
				"Blocked"
			)
		)
	then
		return false
	end

	if self:_HasCompletionFlag(Point)
		or self:_HasCompletionFlag(Parent)
	then
		return false
	end

	return true
end

function GeneratorLogic:_GetAvailablePoints()
	local Result = {}

	for _, Point in ipairs(
		CollectionService:GetTagged("GeneratorPoint")
	) do
		if self:_IsGeneratorAvailable(Point) then
			table.insert(Result, Point)
		end
	end

	return Result
end

--// Generator highlights

function GeneratorLogic:_CreateHighlightContainer()
	local Existing =
		PlayerGui:FindFirstChild(
			self.Settings.ContainerName
		)

	if Existing then
		Existing:Destroy()
	end

	local Folder = Instance.new("Folder")
	Folder.Name = self.Settings.ContainerName
	Folder.Parent = PlayerGui

	self.HighlightContainer = Folder
end

function GeneratorLogic:GetHighlightCount()
	local Count = 0

	for Adornee, Highlight in pairs(self.Highlights) do
		if Adornee.Parent
			and Highlight
			and Highlight.Parent
			and Highlight.Enabled
		then
			Count += 1
		end
	end

	return Count
end

function GeneratorLogic:_RemoveHighlight(Adornee)
	local Highlight = self.Highlights[Adornee]

	if not Highlight then
		return
	end

	self.Highlights[Adornee] = nil
	Highlight:Destroy()

	self._HighlightChangedEvent:Fire(
		Adornee,
		false,
		nil,
		self:GetState()
	)
end

function GeneratorLogic:_ClearHighlights()
	for Adornee in pairs(CopyTable(self.Highlights)) do
		self:_RemoveHighlight(Adornee)
	end
end

function GeneratorLogic:_RefreshHighlights()
	if not self.Settings.HighlightsEnabled then
		self:_ClearHighlights()
		return
	end

	if not self.HighlightContainer
		or not self.HighlightContainer.Parent
	then
		self:_CreateHighlightContainer()
	end

	local ValidAdornees = {}

	for _, Point in ipairs(self:_GetAvailablePoints()) do
		local Adornee = GetGeneratorAdornee(Point)

		if Adornee then
			ValidAdornees[Adornee] = true

			local Highlight = self.Highlights[Adornee]

			if not Highlight or not Highlight.Parent then
				Highlight = Instance.new("Highlight")
				Highlight.Name = "VD_GeneratorESP"
				Highlight.Parent = self.HighlightContainer
				self.Highlights[Adornee] = Highlight

				self._HighlightChangedEvent:Fire(
					Adornee,
					true,
					Highlight,
					self:GetState()
				)
			end

			Highlight.Adornee = Adornee
			Highlight.DepthMode =
				self.Settings.HighlightDepthMode
			Highlight.FillColor =
				self.Settings.HighlightColor
			Highlight.OutlineColor =
				self.Settings.HighlightColor
			Highlight.FillTransparency =
				self.Settings.HighlightFillTransparency
			Highlight.OutlineTransparency =
				self.Settings.HighlightOutlineTransparency
			Highlight.Enabled = true
		end
	end

	for Adornee in pairs(CopyTable(self.Highlights)) do
		if not ValidAdornees[Adornee]
			or not Adornee.Parent
		then
			self:_RemoveHighlight(Adornee)
		end
	end
end

--// Skill-check GUI

function GeneratorLogic:_RefreshGuiReferences()
	local SkillCheckGui =
		PlayerGui:FindFirstChild("SkillCheckPromptGui")

	local CheckFrame =
		SkillCheckGui
		and SkillCheckGui:FindFirstChild("Check")

	local SurvivorGui =
		PlayerGui:FindFirstChild("Survivor-mob")

	local Controls =
		SurvivorGui
		and SurvivorGui:FindFirstChild("Controls")

	local ActionButton =
		Controls
		and Controls:FindFirstChild("action")

	self.SkillCheckGui = SkillCheckGui
	self.CheckFrame = CheckFrame
	self.Line =
		CheckFrame
		and CheckFrame:FindFirstChild("Line")
	self.Goal =
		CheckFrame
		and CheckFrame:FindFirstChild("Goal")
	self.ActionButton = ActionButton
	self.ActionCheck =
		ActionButton
		and ActionButton:FindFirstChild("check")

	return self.CheckFrame ~= nil
		and self.Line ~= nil
		and self.Goal ~= nil
		and self.ActionButton ~= nil
end

function GeneratorLogic:_WaitForSkillCheckGui(Timeout)
	local StartedAt = os.clock()

	repeat
		if not self.Settings.AutoSkillCheck
			or not self._Running
			or self._Destroyed
		then
			return false
		end

		self:_RefreshGuiReferences()

		if self.CheckFrame
			and self.CheckFrame.Visible
			and self.Line
			and self.Goal
			and self.ActionButton
		then
			return true
		end

		task.wait()
	until os.clock() - StartedAt >= Timeout

	return false
end

function GeneratorLogic:_PlaceLineInSuccessZone()
	if not self:_RefreshGuiReferences() then
		return false, "Skill-check GUI was not found"
	end

	self.CheckFrame.Visible = true

	if self.ActionCheck then
		self.ActionCheck.Visible = true
	end

	self.Line.Rotation =
		self.Goal.Rotation
		+ self.Settings.SuccessOffset

	return true
end

function GeneratorLogic:_PressActionButton()
	if not self:_RefreshGuiReferences() then
		return false, "Action button was not found"
	end

	local FireSignalFunction =
		Environment.firesignal

	if type(FireSignalFunction) == "function" then
		local Success = pcall(
			FireSignalFunction,
			self.ActionButton.MouseButton1Down
		)

		if Success then
			return true
		end
	end

	local GetConnectionsFunction =
		Environment.getconnections

	if type(GetConnectionsFunction) == "function" then
		local Success, Connections = pcall(
			GetConnectionsFunction,
			self.ActionButton.MouseButton1Down
		)

		if Success and type(Connections) == "table" then
			local Fired = false

			for _, Connection in ipairs(Connections) do
				local FireSucceeded = false

				local HasFire, FireMethod = pcall(function()
					return Connection.Fire
				end)

				if HasFire and type(FireMethod) == "function" then
					FireSucceeded = pcall(
						FireMethod,
						Connection
					)
				else
					local HasFunction, Callback = pcall(function()
						return Connection.Function
					end)

					if HasFunction
						and type(Callback) == "function"
					then
						FireSucceeded = pcall(Callback)
					end
				end

				if FireSucceeded then
					Fired = true
				end
			end

			if Fired then
				return true
			end
		end
	end

	local VirtualInputManager = nil

	pcall(function()
		VirtualInputManager =
			game:GetService("VirtualInputManager")
	end)

	if VirtualInputManager then
		local Position =
			self.ActionButton.AbsolutePosition
			+ self.ActionButton.AbsoluteSize / 2

		local Success = pcall(function()
			VirtualInputManager:SendMouseButtonEvent(
				Position.X,
				Position.Y,
				0,
				true,
				game,
				0
			)

			task.wait()

			VirtualInputManager:SendMouseButtonEvent(
				Position.X,
				Position.Y,
				0,
				false,
				game,
				0
			)
		end)

		if Success then
			return true
		end
	end

	return false,
		"firesignal, getconnections, and virtual input all failed"
end

function GeneratorLogic:_RecordSkillCheckSuccess(CheckType)
	self.State.SuccessfulSkillChecks += 1
	self.State.LastSkillCheck = tostring(CheckType)

	self._SkillCheckEvent:Fire(
		CheckType,
		self.State.SuccessfulSkillChecks,
		self:GetState()
	)

	self:_SetStatus(
		tostring(CheckType) .. " auto success"
	)
end

function GeneratorLogic:_CompleteSkillCheck(CheckType)
	local Prepared, PrepareError =
		self:_PlaceLineInSuccessZone()

	if not Prepared then
		self:_SetStatus(PrepareError)
		return false
	end

	task.wait()

	local Pressed, PressError =
		self:_PressActionButton()

	if not Pressed then
		self:_SetStatus(
			"Auto success failed: "
				.. tostring(PressError)
		)
		return false
	end

	self:_RecordSkillCheckSuccess(CheckType)
	return true
end

function GeneratorLogic:_HandleNormalSkillCheck()
	if not self.Settings.AutoSkillCheck
		or not self._Running
	then
		return
	end

	self._NormalToken += 1
	local Token = self._NormalToken

	task.spawn(function()
		local GuiReady = self:_WaitForSkillCheckGui(
			self.Settings.NormalCheckTimeout
		)

		if not GuiReady
			or Token ~= self._NormalToken
			or not self.Settings.AutoSkillCheck
		then
			return
		end

		self:_CompleteSkillCheck("Generator")
	end)
end

function GeneratorLogic:_HandleKingScourge(CheckCount)
	if not self.Settings.AutoSkillCheck
		or not self._Running
	then
		return
	end

	self._ScourgeToken += 1
	local Token = self._ScourgeToken
	local TotalChecks =
		math.max(1, tonumber(CheckCount) or 1)

	task.spawn(function()
		for Index = 1, TotalChecks do
			if Token ~= self._ScourgeToken
				or not self.Settings.AutoSkillCheck
				or not self._Running
			then
				return
			end

			local GuiReady = self:_WaitForSkillCheckGui(
				self.Settings.ScourgeCheckTimeout
			)

			if not GuiReady then
				return
			end

			task.wait(self.Settings.ScourgeCheckDelay)

			if not self:_CompleteSkillCheck(
				"King Scourge "
					.. tostring(Index)
					.. "/"
					.. tostring(TotalChecks)
			) then
				return
			end

			if Index < TotalChecks then
				task.wait(self.Settings.ScourgeCheckDelay)
			end
		end
	end)
end

function GeneratorLogic:_BindEvents()
	if self._EventsBound then
		return
	end

	self._EventsBound = true

	table.insert(
		self._Connections,
		SkillCheckEvent.OnClientEvent:Connect(function()
			self:_HandleNormalSkillCheck()
		end)
	)

	table.insert(
		self._Connections,
		KingScourgeStart.OnClientEvent:Connect(
			function(_, _, CheckCount)
				self:_HandleKingScourge(CheckCount)
			end
		)
	)

	table.insert(
		self._Connections,
		KingScourgeEnd.OnClientEvent:Connect(function()
			self._ScourgeToken += 1
		end)
	)

	table.insert(
		self._Connections,
		LocalPlayer.CharacterAdded:Connect(function()
			self._NormalToken += 1
			self._ScourgeToken += 1

			task.wait(0.25)
			self:_RefreshGuiReferences()
		end)
	)
end

--// Settings

function GeneratorLogic:SetAutoSkillCheck(Enabled)
	self.Settings.AutoSkillCheck = Enabled == true

	if not self.Settings.AutoSkillCheck then
		self._NormalToken += 1
		self._ScourgeToken += 1
	end

	self:_SetStatus(
		"Auto Skill Check: "
			.. (
				self.Settings.AutoSkillCheck
					and "ON"
					or "OFF"
			)
	)
end

function GeneratorLogic:SetHighlightsEnabled(Enabled)
	self.Settings.HighlightsEnabled = Enabled == true
	self:_RefreshHighlights()

	self:_SetStatus(
		"Generator Highlights: "
			.. (
				self.Settings.HighlightsEnabled
					and "ON"
					or "OFF"
			)
	)
end

function GeneratorLogic:SetHighlightColor(Color)
	if typeof(Color) ~= "Color3" then
		return false, "Expected Color3"
	end

	self.Settings.HighlightColor = Color
	self:_RefreshHighlights()
	return true
end

function GeneratorLogic:SetAlwaysOnTop(Enabled)
	self.Settings.HighlightDepthMode =
		Enabled
			and Enum.HighlightDepthMode.AlwaysOnTop
			or Enum.HighlightDepthMode.Occluded

	self:_RefreshHighlights()
end

--// Lifecycle

function GeneratorLogic:Start()
	if self._Destroyed then
		return false, "Logic was destroyed"
	end

	if self._Running then
		return true
	end

	self._Running = true
	self.State.Running = true

	self:_BindEvents()
	self:_RefreshHighlights()
	self:_SetStatus(
		"Generator highlights and auto skill check started"
	)

	task.spawn(function()
		while self._Running and not self._Destroyed do
			local Success, ErrorMessage = pcall(function()
				self:_RefreshHighlights()
			end)

			if not Success then
				self:_SetStatus(
					"Generator highlight error: "
						.. tostring(ErrorMessage)
				)
			end

			task.wait(self.Settings.RefreshInterval)
		end
	end)

	return true
end

function GeneratorLogic:Stop()
	if not self._Running then
		return
	end

	self._Running = false
	self.State.Running = false
	self._NormalToken += 1
	self._ScourgeToken += 1
	self:_SetStatus("Generator logic stopped")
end

function GeneratorLogic:Destroy()
	if self._Destroyed then
		return
	end

	self:Stop()
	self._Destroyed = true

	self:_ClearHighlights()

	for _, Connection in ipairs(self._Connections) do
		Disconnect(Connection)
	end

	table.clear(self._Connections)

	if self.HighlightContainer then
		self.HighlightContainer:Destroy()
		self.HighlightContainer = nil
	end

	self._StatusEvent:Destroy()
	self._StateChangedEvent:Destroy()
	self._HighlightChangedEvent:Destroy()
	self._SkillCheckEvent:Destroy()
end

return GeneratorLogic

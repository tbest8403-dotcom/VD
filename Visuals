--// Violence District - Stable Team Color ESP
--// Replace the full GitHub VD/Visuals file with this module.
--// Keeps every player highlight refreshed and recreates deleted containers/highlights.

local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local TeamESP = {}
TeamESP.__index = TeamESP

local function Disconnect(Connection)
	if Connection and Connection.Connected then
		Connection:Disconnect()
	end
end

local function DisconnectList(Connections)
	for _, Connection in ipairs(Connections) do
		Disconnect(Connection)
	end

	table.clear(Connections)
end

local function CopyTable(Source)
	local Result = {}

	for Key, Value in pairs(Source) do
		Result[Key] = Value
	end

	return Result
end

function TeamESP.new(Options)
	Options = Options or {}

	local self = setmetatable({}, TeamESP)

	self.Settings = {
		Enabled = Options.Enabled == true,
		AliveOnly = Options.AliveOnly ~= false,
		IncludeLocalPlayer = Options.IncludeLocalPlayer == true,
		FillTransparency = tonumber(Options.FillTransparency) or 1,
		OutlineTransparency = tonumber(Options.OutlineTransparency) or 0,
		DepthMode = Options.DepthMode or Enum.HighlightDepthMode.AlwaysOnTop,
		ContainerName = Options.ContainerName or "VD_TeamColorESP",
		RefreshDelay = math.max(tonumber(Options.RefreshDelay) or 0.5, 0.1),
		ForcedRefreshDelay = math.max(tonumber(Options.ForcedRefreshDelay) or 3, 1),
	}

	self.State = {
		Running = false,
		Enabled = self.Settings.Enabled,
		HighlightedPlayers = 0,
		Status = "Created",
	}

	self.Highlights = {}
	self.PlayerConnections = {}
	self.GlobalConnections = {}
	self.Container = nil

	self._Running = false
	self._Destroyed = false
	self._LastForcedRefresh = 0

	self._StateChangedEvent = Instance.new("BindableEvent")
	self._HighlightChangedEvent = Instance.new("BindableEvent")
	self._StatusChangedEvent = Instance.new("BindableEvent")

	self:_CreateContainer()

	return self
end

--// Events

function TeamESP:OnStateChanged(Callback)
	return self._StateChangedEvent.Event:Connect(Callback)
end

function TeamESP:OnHighlightChanged(Callback)
	return self._HighlightChangedEvent.Event:Connect(Callback)
end

function TeamESP:OnStatusChanged(Callback)
	return self._StatusChangedEvent.Event:Connect(Callback)
end

function TeamESP:_SetStatus(Status)
	Status = tostring(Status)

	if self.State.Status == Status then
		return
	end

	self.State.Status = Status
	self._StatusChangedEvent:Fire(Status, self:GetState())
	self:_EmitState()
end

function TeamESP:_EmitState()
	self.State.Enabled = self.Settings.Enabled
	self.State.HighlightedPlayers = self:GetHighlightCount()
	self._StateChangedEvent:Fire(self:GetState())
end

--// State

function TeamESP:GetState()
	return {
		Running = self.State.Running,
		Enabled = self.Settings.Enabled,
		AliveOnly = self.Settings.AliveOnly,
		IncludeLocalPlayer = self.Settings.IncludeLocalPlayer,
		HighlightedPlayers = self:GetHighlightCount(),
		Status = self.State.Status,
	}
end

function TeamESP:GetHighlightCount()
	local Count = 0

	for Player, Highlight in pairs(self.Highlights) do
		if Player.Parent
			and Highlight
			and Highlight.Parent == self.Container
			and Highlight.Enabled
			and Highlight.Adornee == Player.Character
		then
			Count += 1
		end
	end

	return Count
end

function TeamESP:GetHighlightedPlayers()
	local Result = {}

	for Player, Highlight in pairs(self.Highlights) do
		if Player.Parent
			and Highlight
			and Highlight.Parent == self.Container
			and Highlight.Enabled
			and Highlight.Adornee == Player.Character
		then
			table.insert(Result, Player)
		end
	end

	return Result
end

--// Container

function TeamESP:_CreateContainer()
	local Existing = PlayerGui:FindFirstChild(self.Settings.ContainerName)

	if Existing then
		Existing:Destroy()
	end

	local Container = Instance.new("Folder")
	Container.Name = self.Settings.ContainerName
	Container.Parent = PlayerGui

	self.Container = Container
	table.clear(self.Highlights)

	return Container
end

function TeamESP:_EnsureContainer()
	if self.Container
		and self.Container.Parent == PlayerGui
	then
		return self.Container
	end

	return self:_CreateContainer()
end

--// Player checks

function TeamESP:_GetPlayerColor(Player)
	if Player.Team then
		return Player.Team.TeamColor.Color
	end

	return Player.TeamColor.Color
end

function TeamESP:_IsAlive(Player)
	local Character = Player.Character

	if not Character then
		return false
	end

	local Humanoid = Character:FindFirstChildOfClass("Humanoid")

	return Humanoid ~= nil and Humanoid.Health > 0
end

function TeamESP:_ShouldHighlight(Player)
	if not self.Settings.Enabled then
		return false
	end

	if Player == LocalPlayer
		and not self.Settings.IncludeLocalPlayer
	then
		return false
	end

	if not Player.Parent or not Player.Character then
		return false
	end

	if self.Settings.AliveOnly and not self:_IsAlive(Player) then
		return false
	end

	return true
end

--// Highlight handling

function TeamESP:_RemoveHighlight(Player, SuppressState)
	local Highlight = self.Highlights[Player]

	if not Highlight then
		return
	end

	self.Highlights[Player] = nil

	pcall(function()
		Highlight:Destroy()
	end)

	self._HighlightChangedEvent:Fire(
		Player,
		false,
		nil,
		self:GetState()
	)

	if not SuppressState then
		self:_EmitState()
	end
end

function TeamESP:_CreateOrUpdateHighlight(Player)
	if not self:_ShouldHighlight(Player) then
		self:_RemoveHighlight(Player, true)
		return nil
	end

	local Character = Player.Character

	if not Character then
		self:_RemoveHighlight(Player, true)
		return nil
	end

	self:_EnsureContainer()

	local Highlight = self.Highlights[Player]
	local NeedsNewHighlight =
		not Highlight
		or Highlight.Parent ~= self.Container
		or Highlight.Adornee ~= Character

	if NeedsNewHighlight then
		if Highlight then
			pcall(function()
				Highlight:Destroy()
			end)
		end

		Highlight = Instance.new("Highlight")
		Highlight.Name = "VD_TeamESP_" .. Player.Name
		Highlight.Parent = self.Container
		self.Highlights[Player] = Highlight

		self._HighlightChangedEvent:Fire(
			Player,
			true,
			Highlight,
			self:GetState()
		)
	end

	local Color = self:_GetPlayerColor(Player)

	Highlight.Adornee = Character
	Highlight.DepthMode = self.Settings.DepthMode
	Highlight.FillColor = Color
	Highlight.OutlineColor = Color
	Highlight.FillTransparency = self.Settings.FillTransparency
	Highlight.OutlineTransparency = self.Settings.OutlineTransparency
	Highlight.Enabled = true

	return Highlight
end

function TeamESP:RefreshPlayer(Player)
	if self._Destroyed then
		return
	end

	self:_CreateOrUpdateHighlight(Player)
	self:_EmitState()
end

function TeamESP:RefreshAll()
	if self._Destroyed then
		return
	end

	self:_EnsureContainer()

	local CurrentPlayers = {}

	for _, Player in ipairs(Players:GetPlayers()) do
		CurrentPlayers[Player] = true
		self:_CreateOrUpdateHighlight(Player)
	end

	for Player in pairs(CopyTable(self.Highlights)) do
		if not CurrentPlayers[Player]
			or not Player.Parent
			or not self:_ShouldHighlight(Player)
		then
			self:_RemoveHighlight(Player, true)
		end
	end

	self:_EmitState()
end

function TeamESP:ClearAll()
	for Player in pairs(CopyTable(self.Highlights)) do
		self:_RemoveHighlight(Player, true)
	end

	self:_EmitState()
end

--// Connection management

function TeamESP:_DisconnectCharacterConnections(Player)
	local Data = self.PlayerConnections[Player]

	if not Data or not Data.CharacterConnections then
		return
	end

	DisconnectList(Data.CharacterConnections)
end

function TeamESP:_BindCharacter(Player, Character)
	local Data = self.PlayerConnections[Player]

	if not Data then
		return
	end

	self:_DisconnectCharacterConnections(Player)
	Data.CharacterConnections = {}

	local Humanoid =
		Character:FindFirstChildOfClass("Humanoid")
		or Character:WaitForChild("Humanoid", 5)

	if Humanoid then
		table.insert(
			Data.CharacterConnections,
			Humanoid.HealthChanged:Connect(function()
				self:_CreateOrUpdateHighlight(Player)
			end)
		)

		table.insert(
			Data.CharacterConnections,
			Humanoid.Died:Connect(function()
				self:_RemoveHighlight(Player)
			end)
		)
	end

	table.insert(
		Data.CharacterConnections,
		Character.AncestryChanged:Connect(function()
			if not Character:IsDescendantOf(game) then
				self:_RemoveHighlight(Player)
			end
		end)
	)

	task.defer(function()
		if self._Destroyed then
			return
		end

		self:_CreateOrUpdateHighlight(Player)
		self:_EmitState()
	end)
end

function TeamESP:_DisconnectPlayer(Player)
	local Data = self.PlayerConnections[Player]

	if Data then
		self:_DisconnectCharacterConnections(Player)
		DisconnectList(Data.Connections)
		self.PlayerConnections[Player] = nil
	end

	self:_RemoveHighlight(Player)
end

function TeamESP:_ConnectPlayer(Player)
	self:_DisconnectPlayer(Player)

	local Data = {
		Connections = {},
		CharacterConnections = {},
	}

	self.PlayerConnections[Player] = Data

	table.insert(
		Data.Connections,
		Player.CharacterAdded:Connect(function(Character)
			self:_BindCharacter(Player, Character)
		end)
	)

	table.insert(
		Data.Connections,
		Player.CharacterRemoving:Connect(function()
			self:_DisconnectCharacterConnections(Player)
			self:_RemoveHighlight(Player)
		end)
	)

	table.insert(
		Data.Connections,
		Player:GetPropertyChangedSignal("Team"):Connect(function()
			self:_CreateOrUpdateHighlight(Player)
		end)
	)

	table.insert(
		Data.Connections,
		Player:GetPropertyChangedSignal("TeamColor"):Connect(function()
			self:_CreateOrUpdateHighlight(Player)
		end)
	)

	if Player.Character then
		self:_BindCharacter(Player, Player.Character)
	end
end

function TeamESP:_StartRefreshLoop()
	task.spawn(function()
		while self._Running and not self._Destroyed do
			local Success, ErrorMessage = pcall(function()
				if self.Settings.Enabled then
					self:RefreshAll()
				elseif next(self.Highlights) ~= nil then
					self:ClearAll()
				end
			end)

			if not Success then
				self:_SetStatus(
					"ESP refresh failed: "
						.. tostring(ErrorMessage)
				)
			end

			local Now = os.clock()

			if Now - self._LastForcedRefresh
				>= self.Settings.ForcedRefreshDelay
			then
				self._LastForcedRefresh = Now

				pcall(function()
					self:_EnsureContainer()

					if self.Settings.Enabled then
						self:RefreshAll()
					end
				end)
			end

			task.wait(self.Settings.RefreshDelay)
		end
	end)
end

--// Settings

function TeamESP:SetEnabled(Enabled)
	self.Settings.Enabled = Enabled == true

	if self.Settings.Enabled then
		self:RefreshAll()
		self:_SetStatus("Team ESP enabled")
	else
		self:ClearAll()
		self:_SetStatus("Team ESP disabled")
	end

	self:_EmitState()
end

function TeamESP:Toggle()
	self:SetEnabled(not self.Settings.Enabled)
	return self.Settings.Enabled
end

function TeamESP:SetAliveOnly(Enabled)
	self.Settings.AliveOnly = Enabled == true
	self:RefreshAll()

	self:_SetStatus(
		"Alive Only: "
			.. (self.Settings.AliveOnly and "ON" or "OFF")
	)
end

function TeamESP:SetIncludeLocalPlayer(Enabled)
	self.Settings.IncludeLocalPlayer = Enabled == true
	self:RefreshAll()

	self:_SetStatus(
		"Include Local Player: "
			.. (
				self.Settings.IncludeLocalPlayer
					and "ON"
					or "OFF"
			)
	)
end

function TeamESP:SetFillTransparency(Value)
	Value = tonumber(Value)

	if not Value then
		return false, "Invalid transparency"
	end

	self.Settings.FillTransparency = math.clamp(Value, 0, 1)
	self:RefreshAll()

	return true
end

function TeamESP:SetOutlineTransparency(Value)
	Value = tonumber(Value)

	if not Value then
		return false, "Invalid transparency"
	end

	self.Settings.OutlineTransparency = math.clamp(Value, 0, 1)
	self:RefreshAll()

	return true
end

function TeamESP:SetDepthMode(DepthMode)
	if typeof(DepthMode) ~= "EnumItem"
		or DepthMode.EnumType ~= Enum.HighlightDepthMode
	then
		return false, "Invalid HighlightDepthMode"
	end

	self.Settings.DepthMode = DepthMode
	self:RefreshAll()

	return true
end

--// Lifecycle

function TeamESP:Start()
	if self._Destroyed then
		return false, "Logic was destroyed"
	end

	if self._Running then
		return true
	end

	self._Running = true
	self.State.Running = true
	self._LastForcedRefresh = os.clock()

	for _, Player in ipairs(Players:GetPlayers()) do
		self:_ConnectPlayer(Player)
	end

	table.insert(
		self.GlobalConnections,
		Players.PlayerAdded:Connect(function(Player)
			self:_ConnectPlayer(Player)
		end)
	)

	table.insert(
		self.GlobalConnections,
		Players.PlayerRemoving:Connect(function(Player)
			self:_DisconnectPlayer(Player)
		end)
	)

	table.insert(
		self.GlobalConnections,
		PlayerGui.ChildRemoved:Connect(function(Child)
			if Child == self.Container then
				self.Container = nil
				table.clear(self.Highlights)

				task.defer(function()
					if self._Running and not self._Destroyed then
						self:_EnsureContainer()
						self:RefreshAll()
					end
				end)
			end
		end)
	)

	if self.Settings.Enabled then
		self:RefreshAll()
	end

	self:_StartRefreshLoop()
	self:_SetStatus("Team ESP logic started")
	self:_EmitState()

	return true
end

function TeamESP:Stop()
	if not self._Running then
		return
	end

	self._Running = false
	self.State.Running = false

	DisconnectList(self.GlobalConnections)

	for Player in pairs(CopyTable(self.PlayerConnections)) do
		self:_DisconnectPlayer(Player)
	end

	self:ClearAll()
	self:_SetStatus("Team ESP logic stopped")
	self:_EmitState()
end

function TeamESP:Destroy()
	if self._Destroyed then
		return
	end

	self:Stop()
	self._Destroyed = true

	if self.Container then
		self.Container:Destroy()
		self.Container = nil
	end

	self._StateChangedEvent:Destroy()
	self._HighlightChangedEvent:Destroy()
	self._StatusChangedEvent:Destroy()
end

return TeamESP
